    {
      "parameters": {
        "jsCode": "return items.map(item => ({\n     json: {\n       id: item.json.id,\n       subject: item.json.payload?.headers?.find(h => h.name === 'Subject')?.value || item.json.subject || '',\n       from: item.json.payload?.headers?.find(h => h.name === 'From')?.value || item.json.from || '',\n       snippet: item.json.snippet || ''\n     }\n   }));\n"
      },
      "id": "5ea3b1d9-1040-4010-b704-5f300e46436f",
      "name": "Extract Email Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        480
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googlePalmApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n       \"contents\": [{\n         \"parts\": [{\n           \"text\": \"You are sorting job-application-related emails into exactly one category.\\n\\nCategories:\\n- Applied: confirmation that an application was submitted/received\\n- Interview: invitation to schedule or attend an interview\\n- Assessment: online test, coding challenge, take-home task, or skills assessment request\\n- Rejected: rejection / moving forward with other candidates / not selected\\n- Offer: job offer email\\n- Other: anything not clearly job-application related (newsletters, LinkedIn digests, etc.)\\n\\nEmail Subject: {{ $json.subject }}\\nFrom: {{ $json.from }}\\nSnippet: {{ $json.snippet }}\\n\\nRespond with ONLY valid JSON, no markdown, no explanation:\\n{\\\"category\\\": \\\"one of: Applied, Interview, Assessment, Rejected, Offer, Other\\\", \\\"confidence\\\": \\\"high/medium/low\\\"}\"\n         }]\n       }]\n     }",
        "options": {}
      },
      "id": "04abd9d5-b20e-41b2-95d5-74682eb0d507",
      "name": "Call Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        448,
        480
      ],
      "retryOnFail": true,
      "credentials": {
        "googlePalmApi": {
          "id": "KZgcQjIuL3pDOGS6",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map((item, i) => {\n  const raw = item.json.candidates[0].content.parts[0].text;\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  let parsed;\n  try {\n    parsed = JSON.parse(cleaned);\n  } catch (e) {\n    parsed = { category: 'Other', confidence: 'low' };\n  }\n  const source = $('Extract Email Fields').all()[i].json;\n  return { json: { ...source, category: parsed.category, confidence: parsed.confidence } };\n});"
      },
