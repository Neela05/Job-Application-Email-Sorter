{
  "name": "Job Application Email sorter",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "q": "category:primary -label:Applied -label:Interview -label:Assessment -label:Rejected -label:Offer -label:Other"
        }
